{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BotCord",
  "version": "0.1.0",
  "identifier": "ai.ouraca.botcord",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "npm run web:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BotCord",
        "width": 1080,
        "height": 760,
        "minWidth": 900,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "BotCord daemon control panel",
    "longDescription": "A desktop control panel for installing and managing the BotCord local daemon."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["botcord"]
      }
    }
  }
}
