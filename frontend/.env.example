# 前端站点地址 / 取消回跳使用的前端站点地址
NEXT_PUBLIC_APP_URL=https://www.botcord.chat
NEXT_PUBLIC_BOTCORD_GENERAL_URL=/chats/explore/rooms

# 浏览器请求与 BFF 回退使用的公共 API 基地址
NEXT_PUBLIC_HUB_BASE_URL=https://api.botcord.chat

# 聊天消息状态是否显示（控制如 1/n delivered 这类状态徽章）
# true/1/on/yes 显示；false/0/off/no 隐藏；默认 true
SHOW_MESSAGE_STATUS=true

# Supabase 项目 URL（服务端/客户端/middleware 共用）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase 浏览器安全密钥（推荐变量名）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# 服务端注册确认邮件使用：生成 Supabase 确认链接并通过 Resend 发送 BotCord 模板邮件
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=BotCord <noreply@botcord.chat>

# Drizzle ORM 与脚本使用的 PostgreSQL 连接串（生产推荐 Session Pooler）
# Supabase Session Pooler 示例（推荐）:
# SUPABASE_DB_URL=postgresql://postgres.your-project:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
# 直连示例（仅本地/管理用途）:
# SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.your-project:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# serverless 建议每实例连接池大小为 1，防止总连接数打满数据库
SUPABASE_DB_POOL_MAX=1

# 使用 Supabase Pooler 时建议关闭 prepared statements（postgres-js）
SUPABASE_DB_PREPARE=false

# Stripe 服务端密钥（用于创建 checkout session）
STRIPE_SECRET_KEY=sk_test_xxx

# 套餐项未配置 currency 时的默认币种（默认 usd）
STRIPE_TOPUP_CURRENCY=usd

# 充值套餐配置（JSON 数组字符串，代码实际读取此变量）
STRIPE_TOPUP_PACKAGES=[{"package_code":"coin_1","stripe_price_id":"price_xxx","coin_amount_minor":"100","fiat_amount":"1.00"}]

# Beta 邀请码门控（true = 需要邀请码，false = 开放注册）
NEXT_PUBLIC_BETA_GATE_ENABLED=false

# 绑定凭证签名密钥（用于一次性绑定票据）
BIND_PROOF_SECRET=replace-with-long-random-secret
