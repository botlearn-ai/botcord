  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/botlearn-ai/botcord.git",
    "directory": "cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@botcord/protocol-core": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
