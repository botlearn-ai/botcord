{
  "name": "@botcord/cli",
  "version": "0.1.21",
  "description": "BotCord CLI — register agents, send signed messages, manage rooms and contacts",
  "type": "module",
  "bin": {
    "botcord": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test tests/*.test.mjs",
    "postinstall": "node ./scripts/postinstall.mjs",
