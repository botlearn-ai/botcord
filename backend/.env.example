# Database
DATABASE_URL=postgresql+asyncpg://botcord:botcord@localhost:5432/botcord
DATABASE_SCHEMA=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# Endpoint probe
ENDPOINT_PROBE_ENABLED=true
ENDPOINT_PROBE_TIMEOUT_SECONDS=5

# Inbox long-polling
INBOX_POLL_MAX_TIMEOUT=30

# File upload
FILE_STORAGE_BACKEND=disk
FILE_UPLOAD_DIR=/tmp/botcord/uploads
FILE_MAX_SIZE_BYTES=10485760
FILE_TTL_HOURS=1
FILE_CLEANUP_INTERVAL_SECONDS=300

# Supabase Storage (required when FILE_STORAGE_BACKEND=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=botcord-files

# Set to true to allow private/localhost endpoint URLs (dev only)
ALLOW_PRIVATE_ENDPOINTS=false

# Beta invite gate (true = require invite code, false = open registration)
BETA_GATE_ENABLED=false

# Public frontend origin used in links and auth redirects.
FRONTEND_BASE_URL=https://www.botcord.chat
# Optional comma-separated extra signup redirect origins (production should keep this narrow).
AUTH_ALLOWED_ORIGINS=

# Signup confirmation email service (used by /api/auth/signup)
RESEND_API_KEY=
RESEND_FROM_EMAIL=BotCord <noreply@mail.app.botcord.chat>

# Cloud Agent
CLOUD_AGENT_FEATURE_ENABLED=false
CLOUD_AGENT_MAX_PER_USER=5
CLOUD_AGENT_DEFAULT_MAX_AGENTS_PER_DAEMON=5
# Use e2b for any environment where Cloud Agents should actually reply.
# Local tests/dev may set this to fake intentionally.
CLOUD_AGENT_DEFAULT_PROVIDER=e2b
CLOUD_AGENT_IDLE_PAUSE_SECONDS=300
CLOUD_AGENT_IDLE_SWEEP_INTERVAL_SECONDS=60
E2B_API_KEY=
DEEPSEEK_API_KEY=
# Optional: provision per-user model API keys through new-api and inject them
# into Cloud Agent sandboxes as NEW_API_*/OPENAI_*/DEEPSEEK_* env vars.
NEW_API_BASE_URL=http://localhost:3000
NEW_API_INTERNAL_SECRET=
# Optional Fernet key or raw secret used to encrypt per-user new-api keys at rest.
# Falls back to JWT_SECRET when unset.
NEW_API_CREDENTIAL_ENCRYPTION_KEY=
NEW_API_INITIAL_CREDIT_USD=5

# BotLearn trusted course-session runtime profiles
BOTLEARN_INTEGRATION_ENABLED=false
BOTLEARN_ALLOWED_ORIGINS=
BOTLEARN_SESSION_TTL_SECONDS=900
# Must match BotLearn Course BOTCORD_RUNTIME_PROFILE_SECRET.
BOTLEARN_RUNTIME_PROFILE_SECRET=
