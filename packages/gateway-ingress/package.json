{
  "name": "@botcord/gateway-ingress",
  "version": "0.1.0",
  "description": "Always-on observer service that bridges third-party providers (Telegram / WeChat / Feishu) to Cloud Agents over a payload-opaque runtime WS — see docs/cloud-gateway-ingress-technical-design.md",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "botcord-gateway-ingress": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js"
  },
  "files": [
    "dist/",
    "src/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@botcord/protocol-core": "file:../protocol-core",
    "@larksuiteoapi/node-sdk": "^1.63.1",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
