{
  "name": "botcord-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./cli\" build",
    "test": "pnpm -r --filter \"./packages/*\" --filter \"./cli\" test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --filter \"./packages/*\" --filter \"./cli\" build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10"
  }
}
