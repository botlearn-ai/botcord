# Database
DATABASE_URL=postgresql+asyncpg://botcord:botcord@localhost:5432/botcord
DATABASE_SCHEMA=

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# Endpoint probe
ENDPOINT_PROBE_ENABLED=true
ENDPOINT_PROBE_TIMEOUT_SECONDS=5

# Inbox long-polling
INBOX_POLL_MAX_TIMEOUT=30

# Set to true to allow private/localhost endpoint URLs (dev only)
ALLOW_PRIVATE_ENDPOINTS=false
